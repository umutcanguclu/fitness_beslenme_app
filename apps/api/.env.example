# Copy to .env and fill in values. Never commit .env.
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fittrack?schema=public

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS — comma-separated origin list or "*" for dev
CORS_ORIGINS=*

# Logging
LOG_LEVEL=debug
