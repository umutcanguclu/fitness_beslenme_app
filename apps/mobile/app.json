{
  "expo": {
    "name": "FitTrack",
    "slug": "fittrack",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "fittrack",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "studio.temreon.fittrack"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0F14"
      },
      "package": "studio.temreon.fittrack",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
