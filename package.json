{
  "name": "fittrack",
  "private": true,
  "version": "0.1.0",
  "description": "FitTrack — a personal fitness tracking monorepo (Flutter + Fastify + Postgres).",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:api": "pnpm --filter @fittrack/api dev",
    "exercises:sync": "pnpm --filter @fittrack/exercise-db sync && node -e \"require('fs').copyFileSync('packages/exercise-db/src/exercises.json','apps/mobile/assets/exercises.json')\"",
    "dev:mobile": "cd apps/mobile && flutter run",
    "mobile:analyze": "cd apps/mobile && flutter analyze",
    "mobile:format": "cd apps/mobile && dart format lib test",
    "mobile:l10n": "cd apps/mobile && flutter gen-l10n",
    "mobile:build:android": "cd apps/mobile && flutter build apk",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test:api": "pnpm --filter @fittrack/api test",
    "test:mobile": "cd apps/mobile && flutter test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma"
    ]
  }
}
